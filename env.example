# ============================================================
# Environment Variables for Vercel Deployment
# Add these in: Vercel Dashboard → Project Settings → Environment Variables
# DO NOT commit a real .env file with secrets to GitHub
# ============================================================

# Supabase Project URL (visible — safe to share)
SUPABASE_URL=https://ohpqcipoveelgnliiaos.supabase.co

# Supabase Service Role Key (SECRET — NEVER expose in browser code)
# Get from: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic Claude API key (for AI Counsellor)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx
